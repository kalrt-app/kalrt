generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Notification {
  id           String             @id
  storeId      String
  subscriberId String
  type         NotificationType
  provider     String
  status       NotificationStatus @default(PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  errorMessage String?
  externalId   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime
  Store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  Subscriber   Subscriber         @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([storeId])
  @@index([subscriberId])
}

model Product {
  id               String    @id
  storeId          String
  shopifyProductId String
  title            String
  handle           String?
  imageUrl         String?
  price            Decimal?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  Variant          Variant[]

  @@unique([storeId, shopifyProductId])
  @@index([storeId])
}

model Store {
  id                 String         @id
  shopDomain         String         @unique
  shopName           String?
  accessToken        String
  email              String?
  plan               Plan           @default(FREE)
  notificationsUsed  Int            @default(0)
  notificationsLimit Int            @default(50)
  installedAt        DateTime       @default(now())
  uninstalledAt      DateTime?
  settings           Json           @default("{}")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  Notification       Notification[]
  Product            Product[]
  Subscriber         Subscriber[]
  Template           Template[]
}

model Subscriber {
  id           String           @id
  storeId      String
  email        String?
  phone        String?
  productId    String
  variantId    String?
  productTitle String?
  variantTitle String?
  status       SubscriberStatus @default(WAITING)
  notifiedAt   DateTime?
  convertedAt  DateTime?
  source       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime
  Notification Notification[]
  Store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@index([storeId])
  @@index([variantId])
}

model Template {
  id        String       @id
  storeId   String
  type      TemplateType
  name      String
  subject   String?
  body      String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime
  Store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Variant {
  id                String   @id
  productId         String
  shopifyVariantId  String
  title             String?
  sku               String?
  price             Decimal?
  inventoryQuantity Int      @default(0)
  inStock           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  Product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyVariantId])
  @@index([inStock])
  @@index([productId])
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum Plan {
  FREE
  STARTER
  GROWTH
  SCALE
}

enum SubscriberStatus {
  WAITING
  NOTIFIED
  CONVERTED
  UNSUBSCRIBED
  BOUNCED
}

enum TemplateType {
  RESTOCK_EMAIL
  RESTOCK_SMS
  THANKYOU_EMAIL
  REMINDER_EMAIL
}
