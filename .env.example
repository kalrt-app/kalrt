# ============================================
# RESTOCKIT ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================

# 🔐 SHOPIFY (from Aamir's Partners account)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_inventory,write_inventory,read_customers,write_customers
HOST=https://your-app.vercel.app

# 🗄️ DATABASE (Supabase - we create)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# 📧 EMAIL (Resend - Aamir has it)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notify@fervogear.com

# 📱 SMS - Twilio (Phase 2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# 🔧 APP SETTINGS
NODE_ENV=development
PORT=3000
SESSION_SECRET=generate-random-string-here
