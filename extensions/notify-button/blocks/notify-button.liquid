{% comment %}
  KALRT Notify Me Button
  Shows on out-of-stock products to collect email/SMS signups
{% endcomment %}

{% if product.available == false or product.selected_or_first_available_variant.available == false %}
<div class="kalrt-notify-container" data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
  <style>
    .kalrt-notify-container {
      margin: 16px 0;
      font-family: inherit;
    }
    .kalrt-notify-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .kalrt-input-group {
      display: flex;
      gap: 8px;
    }
    .kalrt-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      font-size: 14px;
    }
    .kalrt-input:focus {
      outline: none;
      border-color: {{ block.settings.button_color }};
      box-shadow: 0 0 0 2px {{ block.settings.button_color }}20;
    }
    .kalrt-button {
      padding: 12px 24px;
      background: {{ block.settings.button_color }};
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .kalrt-button:hover {
      opacity: 0.9;
    }
    .kalrt-button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .kalrt-success {
      padding: 16px;
      background: #ecfdf5;
      border: 1px solid #10b981;
      border-radius: 6px;
      color: #065f46;
      text-align: center;
    }
    .kalrt-error {
      padding: 12px;
      background: #fef2f2;
      border: 1px solid #ef4444;
      border-radius: 6px;
      color: #b91c1c;
      font-size: 13px;
    }
    .kalrt-label {
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 4px;
      display: block;
    }
    .kalrt-powered {
      margin-top: 8px;
      font-size: 11px;
      color: #9ca3af;
      text-align: center;
    }
  </style>

  <div id="kalrt-form-{{ product.id }}" class="kalrt-notify-form">
    <label class="kalrt-label">Get notified when this is back in stock</label>

    <div class="kalrt-input-group">
      <input
        type="email"
        class="kalrt-input"
        id="kalrt-email-{{ product.id }}"
        placeholder="Enter your email"
        required
      >
    </div>

    {% if block.settings.collect_phone %}
    <div class="kalrt-input-group">
      <input
        type="tel"
        class="kalrt-input"
        id="kalrt-phone-{{ product.id }}"
        placeholder="Phone number (optional)"
      >
    </div>
    {% endif %}

    <button
      type="button"
      class="kalrt-button"
      id="kalrt-submit-{{ product.id }}"
      onclick="kalrtSubmit('{{ product.id }}', '{{ product.selected_or_first_available_variant.id }}')"
    >
      {{ block.settings.button_text }}
    </button>

    <div id="kalrt-error-{{ product.id }}" class="kalrt-error" style="display: none;"></div>
  </div>

  <div id="kalrt-success-{{ product.id }}" class="kalrt-success" style="display: none;">
    ✓ {{ block.settings.success_message }}
  </div>

  <div class="kalrt-powered">Powered by KALRT</div>

  <script>
    async function kalrtSubmit(productId, variantId) {
      const email = document.getElementById('kalrt-email-' + productId).value;
      const phone = document.getElementById('kalrt-phone-' + productId)?.value || '';
      const button = document.getElementById('kalrt-submit-' + productId);
      const form = document.getElementById('kalrt-form-' + productId);
      const success = document.getElementById('kalrt-success-' + productId);
      const errorDiv = document.getElementById('kalrt-error-' + productId);

      if (!email || !email.includes('@')) {
        errorDiv.textContent = 'Please enter a valid email address';
        errorDiv.style.display = 'block';
        return;
      }

      button.disabled = true;
      button.textContent = 'Submitting...';
      errorDiv.style.display = 'none';

      try {
        const response = await fetch('/apps/kalrt/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            phone,
            productId,
            variantId,
            productTitle: '{{ product.title | escape }}',
            variantTitle: '{{ product.selected_or_first_available_variant.title | escape }}'
          })
        });

        if (response.ok) {
          form.style.display = 'none';
          success.style.display = 'block';
        } else {
          const data = await response.json();
          throw new Error(data.error || 'Something went wrong');
        }
      } catch (err) {
        errorDiv.textContent = err.message;
        errorDiv.style.display = 'block';
        button.disabled = false;
        button.textContent = '{{ block.settings.button_text }}';
      }
    }
  </script>
</div>
{% endif %}

{% schema %}
{
  "name": "KALRT Notify Button",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Notify Me When Available"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#ff6b4a"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "You're on the list! We'll email you when it's back."
    },
    {
      "type": "checkbox",
      "id": "collect_phone",
      "label": "Collect Phone Number (SMS)",
      "default": false
    }
  ]
}
{% endschema %}
